

  <div class="auth-main">
    <div class="auth-wrapper v3">
      <div class="auth-form">
        <div class="auth-header">
          <h4 class="mb-0"><b>Task Manager</b></h4>
        </div>
        <div class="card my-5">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-end mb-4">
              <h3 class="mb-0"><b>Login</b></h3>
              <a href="/register" class="link-primary">Don't have an account?</a>
            </div>

            <% if (typeof message !== 'undefined' && message) { %>
              <div class="alert alert-success alert-dismissible fade show" role="alert">
                <% if (message === 'password_reset_successfully') { %>
                  Password reset successfully! Please login with your new password.
                <% } else if (message === 'server_error') { %>
                  Server error. Please try again.
                <% } else if (message === 'logged_out_successfully') { %>
                  You have been logged out successfully.
                <% } else if (message === 'not_authenticated') { %>
                  Please login to access that page.
                <% } %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% } %>

            <form action="/login" method="POST">
              <div class="form-group mb-3">
                <label class="form-label">Email Address</label>
                <input type="email" name="email" class="form-control" placeholder="Email Address" required>
              </div>
              <div class="form-group mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="Password" required>
              </div>
              <div class="d-flex mt-1 justify-content-between">
                
                <a href="/forgot-password"><h5 class="text-secondary f-w-400">Forgot Password?</h5></a>
              </div>
              <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary">Login</button>
              </div>
            </form>
            
           
          </div>
        </div>
        
      </div>
    </div>
  </div>
  <!-- [ Main Content ] end -->
 