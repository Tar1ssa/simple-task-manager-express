

  <div class="auth-main">
    <div class="auth-wrapper v3">
      <div class="auth-form">
        <div class="auth-header">
            <h4 class="mb-0"><b>Task Manager</b></h4>
        </div>
        <div class="card my-5">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-end mb-4">
              <h3 class="mb-0"><b>Forgot Password</b></h3>
              <a href="/login" class="link-primary">Back to Login</a>
            </div>

            <% if (typeof message !== 'undefined' && message) { %>
              <div class="alert alert-info alert-dismissible fade show" role="alert">
                <% if (message === 'reset_token_generated') { %>
                  Password reset token generated! Check the console log for your reset token and paste it below.
                <% } else if (message === 'user_not_found') { %>
                  No account found with that email address.
                <% } else if (message === 'server_error') { %>
                  Server error. Please try again.
                <% } else if (message === 'invalid_token') { %>
                  Invalid reset token. Please try again.
                <% } else if (message === 'token_verified') { %>
                  Token verified! Please enter your new password below.
                <% } %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% } %>

            <% if (!tokenVerified) { %>
            <form action="/forgot-password" method="POST" id="emailForm">
              <div class="form-group mb-3">
                <label class="form-label">Email Address</label>
                <input type="email" name="email" class="form-control" placeholder="Email Address" required>
              </div>
              <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary">Send Reset Token</button>
              </div>
            </form>

            <form action="/forgot-password" method="POST" id="tokenForm" style="display: none;">
              <div class="form-group mb-3">
                <label class="form-label">Reset Token</label>
                <input type="text" name="token" class="form-control" placeholder="Paste your reset token here" required>
                <div class="form-text">Copy the token from the browser here.</div>
                <small id="tokenText"></small>
              </div>
              <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary">Verify Token</button>
              </div>
            </form>
            <% } %>

            <% if (tokenVerified) { %>
            <form action="/forgot-password" method="POST">
              <input type="hidden" name="token" value="<%= verifiedToken %>">
              <div class="form-group mb-3">
                <label class="form-label">New Password</label>
                <input type="password" name="newPassword" class="form-control" placeholder="New Password" minlength="6" required>
                <div class="form-text">Password must be at least 6 characters long.</div>
              </div>
              <div class="form-group mb-3">
                <label class="form-label">Confirm New Password</label>
                <input type="password" name="confirmPassword" class="form-control" placeholder="Confirm New Password" required>
              </div>
              <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary">Reset Password</button>
              </div>
            </form>
            <% } %>
          </div>
        </div>
        
      </div>
    </div>
  </div>
  <!-- [ Main Content ] end -->

  <script>
    const params = new URLSearchParams(window.location.search);

    const token = params.get('token');

    document.getElementById('tokenText').textContent = token;
</script>