
  <div class="auth-main">
    <div class="auth-wrapper v3">
      <div class="auth-form">
        <div class="auth-header">
            <h4 class="mb-0"><b>Task Manager</b></h4>
        </div>
        <div class="card my-5">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-end mb-4">
              <h3 class="mb-0"><b>Reset Password</b></h3>
              <a href="/login" class="link-primary">Back to Login</a>
            </div>

            <% if (typeof message !== 'undefined' && message) { %>
              <div class="alert alert-info alert-dismissible fade show" role="alert">
                <% if (message === 'invalid_token') { %>
                  Invalid or expired reset token.
                <% } else if (message === 'user_not_found') { %>
                  User not found.
                <% } else if (message === 'server_error') { %>
                  Server error. Please try again.
                <% } %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% } %>

            <form action="/reset-password" method="POST">
              <div class="form-group mb-3">
                <label class="form-label">Reset Token</label>
                <input type="text" name="token" class="form-control" placeholder="Enter reset token" required>
                <div class="form-text">Check the console log for the reset token sent to your email.</div>
              </div>
              <div class="form-group mb-3">
                <label class="form-label">New Password</label>
                <input type="password" name="newPassword" class="form-control" placeholder="New Password" minlength="6" required>
                <div class="form-text">Password must be at least 6 characters long.</div>
              </div>
              <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary">Reset Password</button>
              </div>
            </form>
          </div>
        </div>
        <div class="auth-footer row">
          <div class="col my-1">
            <p class="m-0">Copyright © <a href="#">Codedthemes</a></p>
          </div>
          <div class="col-auto my-1">
            <ul class="list-inline footer-link mb-0">
              <li class="list-inline-item"><a href="#">Home</a></li>
              <li class="list-inline-item"><a href="#">Privacy Policy</a></li>
              <li class="list-inline-item"><a href="#">Contact us</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- [ Main Content ] end -->
 